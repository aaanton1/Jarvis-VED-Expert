generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Idea {
  id         String   @id @default(uuid())
  keyword    String
  status     String   @default("Draft")
  score      Float?
  reportPath String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
